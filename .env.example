# MongoDB
MONGO_URI=mongodb://localhost:27017/

# Google Sheets integration
# 1) Create a Google Cloud service account
# 2) Enable Google Sheets API + Google Drive API
# 3) Download JSON key and set absolute path below
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json

# OR put full JSON content into GOOGLE_CREDENTIALS_JSON (single line JSON string)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Spreadsheet ID from the sheet URL
GOOGLE_SHEET_ID=1pmaRC2mTIEV2iXvO-dZFPm9FkcAj0PiOu7gVOPSj3yM

# Worksheet/tab name inside that sheet
GOOGLE_SHEET_WORKSHEET=Predictions
